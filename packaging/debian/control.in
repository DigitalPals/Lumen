Source: lumen
Section: utils
Priority: optional
Maintainer: @MAINTAINER@
Build-Depends:
 debhelper-compat (= 13),
 desktop-file-utils
Standards-Version: 4.7.0
Rules-Requires-Root: no
Homepage: https://lumen.app/
Vcs-Git: https://github.com/lumen-rs/lumen.git
Vcs-Browser: https://github.com/lumen-rs/lumen

Package: lumen
Architecture: amd64 arm64
Depends:
 ${shlibs:Depends},
 ${misc:Depends},
 hicolor-icon-theme
Suggests:
 dbus-user-session,
 bluez,
 network-manager,
 upower,
 power-profiles-daemon,
 pipewire-pulse,
 wireplumber
Description: Lumen desktop shell
 Lumen is a compositor agnostic Wayland shell with extensive customization.
 It includes a bar, notifications, OSD, wallpaper, and device controls.
