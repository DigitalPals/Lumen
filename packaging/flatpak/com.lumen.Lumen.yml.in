app-id: com.lumen.Lumen
runtime: org.gnome.Platform
runtime-version: "49"
sdk: org.gnome.Sdk
sdk-extensions:
  - org.freedesktop.Sdk.Extension.rust-stable
  - org.freedesktop.Sdk.Extension.llvm21
command: lumen-settings
finish-args:
  - --share=ipc
  - --socket=wayland
  - --device=dri
  - --filesystem=xdg-config/lumen:create
  - --filesystem=xdg-data/lumen:create
  - --filesystem=xdg-cache/lumen:create
  - --talk-name=org.freedesktop.Notifications
  - --system-talk-name=org.bluez
  - --system-talk-name=org.freedesktop.NetworkManager
  - --system-talk-name=org.freedesktop.UPower
  - --system-talk-name=net.hadess.PowerProfiles
build-options:
  append-path: /usr/lib/sdk/rust-stable/bin
  env:
    CARGO_HOME: /run/build/lumen/cargo-home
    CARGO_PROFILE_RELEASE_CODEGEN_UNITS: "16"
    CARGO_PROFILE_RELEASE_LTO: "false"
    BINDGEN_EXTRA_CLANG_ARGS: -I/usr/lib/sdk/llvm21/lib/clang/21/include
    LIBCLANG_PATH: /usr/lib/sdk/llvm21/lib
    LUMEN_RESOURCES_DIR: /app/share/lumen/icons/hicolor/scalable/actions
modules:
  - name: gtk4-layer-shell
    buildsystem: meson
    sources:
      - type: git
        url: https://github.com/wmww/gtk4-layer-shell.git
        tag: v1.3.0

  - name: lumen
    buildsystem: simple
    build-commands:
      - cargo build --release --locked --offline --bin lumen --bin lumen-settings
      - mkdir -p target/flatpak-completions
      - target/release/lumen completions bash > target/flatpak-completions/completions.bash
      - target/release/lumen completions zsh > target/flatpak-completions/_lumen
      - target/release/lumen completions fish > target/flatpak-completions/lumen.fish
      - install -Dm0755 target/release/lumen /app/bin/lumen
      - install -Dm0755 target/release/lumen-settings /app/bin/lumen-settings
      - install -Dm0644 packaging/flatpak/com.lumen.Lumen.desktop /app/share/applications/com.lumen.Lumen.desktop
      - install -Dm0644 packaging/flatpak/com.lumen.Lumen.metainfo.xml /app/share/metainfo/com.lumen.Lumen.metainfo.xml
      - install -Dm0644 assets/lumen.png /app/share/icons/hicolor/256x256/apps/com.lumen.Lumen.png
      - install -Dm0644 resources/lumen-settings.svg /app/share/icons/hicolor/scalable/apps/lumen-settings.svg
      - mkdir -p /app/share/lumen
      - cp -r resources/icons /app/share/lumen/icons
      - mkdir -p /app/share/icons
      - cp -r resources/icons/hicolor/. /app/share/icons/hicolor/
      - install -Dm0644 resources/lumen.service /app/share/systemd/user/lumen.service
      - sed -i 's#/usr/bin/lumen#/app/bin/lumen#g' /app/share/systemd/user/lumen.service
      - install -Dm0644 target/flatpak-completions/completions.bash /app/share/bash-completion/completions/lumen
      - install -Dm0644 target/flatpak-completions/_lumen /app/share/zsh/site-functions/_lumen
      - install -Dm0644 target/flatpak-completions/lumen.fish /app/share/fish/vendor_completions.d/lumen.fish
    sources:
      - type: dir
        path: "@SOURCE_DIR@"
