### Lumen Configuration - Model Usage Module

## Model Usage Module Configuration

settings-modules-model-usage-claude-enabled = Claude Code
    .description = Show usage for the Claude Code CLI's subscription

settings-modules-model-usage-codex-enabled = Codex CLI
    .description = Show usage for the Codex CLI's subscription

settings-modules-model-usage-provider-order = Provider Order
    .description = Which provider tab comes first in the dropdown

settings-modules-model-usage-refresh-interval-seconds = Refresh Interval
    .description = Polling interval in seconds (minimum 120; lower values risk endpoint rate limits)

settings-modules-model-usage-dropdown-scale = Dropdown Size
    .description = Dropdown size scale, applied on top of the global UI scale

settings-modules-model-usage-icon-name = Icon
    .description = Icon for the bar button

settings-modules-model-usage-border-show = Show Border
    .description = Display border around button

settings-modules-model-usage-border-color = Border Color
    .description = Border color token

settings-modules-model-usage-icon-show = Show Icon
    .description = Display module icon

settings-modules-model-usage-icon-color = Icon Color
    .description = Icon foreground color

settings-modules-model-usage-icon-bg-color = Icon Background
    .description = Icon container background color token

settings-modules-model-usage-label-show = Show Label
    .description = Display usage label

settings-modules-model-usage-label-color = Label Color
    .description = Label text color token

settings-modules-model-usage-label-max-length = Label Max Length
    .description = Max label characters before truncation with ellipsis. Set to 0 to disable

settings-modules-model-usage-button-bg-color = Button Background
    .description = Button background color token

settings-modules-model-usage-left-click = Left Click
    .description = Action on left click

settings-modules-model-usage-right-click = Right Click
    .description = Action on right click

settings-modules-model-usage-middle-click = Middle Click
    .description = Action on middle click

settings-modules-model-usage-scroll-up = Scroll Up
    .description = Action on scroll up

settings-modules-model-usage-scroll-down = Scroll Down
    .description = Action on scroll down
